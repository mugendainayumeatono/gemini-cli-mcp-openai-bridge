{
    "name": "@intelligentinternet/gemini-cli-mcp-openai-bridge",
    "version": "0.0.2",
    "engines": {
        "node": ">=18.0.0"
    },
    "type": "module",
    "private": true,
    "repository": "Intelligent-Internet/gemini-cli-common-bridge",
    "workspaces": [
        "bridge-server"
    ],
    "scripts": {
        "build": "npm run build --workspace=@intelligentinternet/gemini-cli-mcp-openai-bridge",
        "start": "npm start --workspace=@intelligentinternet/gemini-cli-mcp-openai-bridge --",
        "publish:bridge-server": "npm publish --workspace=@intelligentinternet/gemini-cli-mcp-openai-bridge --access public"
    },
    "bin": {
        "gemini-cli-bridge": "bridge-server/dist/index.js"
    },
    "files": [
        "bundle/",
        "README.md",
        "LICENSE",
        "NOTICE"
    ]
}
